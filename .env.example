# Copy this file to .env before running docker compose.

# Required for /ws/shipments/nearby when sending {"type":"passenger"}.
# MySQL / MariaDB Laravel example:
# SHIPMENT_DB_DRIVER=mysql
# SHIPMENT_DB_DSN=laravel_user:laravel_pass@tcp(host.docker.internal:3306)/laravel_db?parseTime=true
# SHIPMENT_TABLE=shipments
# SHIPMENT_ORIGIN_LAT_COLUMN=start_lat
# SHIPMENT_ORIGIN_LNG_COLUMN=start_lng

# PostgreSQL Laravel example:
# SHIPMENT_DB_DRIVER=postgres
# SHIPMENT_DB_DSN=host=host.docker.internal port=5432 user=laravel_user password=laravel_pass dbname=laravel_db sslmode=disable
# SHIPMENT_TABLE=shipments
# SHIPMENT_ORIGIN_LAT_COLUMN=start_lat
# SHIPMENT_ORIGIN_LNG_COLUMN=start_lng
