# Copy to .env for local development. Do not commit real secrets.
# Used by docker-compose and local `go run ./cmd/server`.

# ── HTTP server ──────────────────────────────────────────────────────────────
PORT=8080
GIN_MODE=release

# ── Redis (live GPS state, route cache, Pub/Sub, driver GEO) ─────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── PostGIS (road graph + GPS history) ───────────────────────────────────────
# Required for internal routing and GPS batch persistence.
# Docker default: host=localhost port=5433 user=geo password=geo_secret dbname=geodb sslmode=disable
POSTGRES_DSN=

# Comma-separated region suffixes for multi-region road tables (optional).
# Example: tehran,mashhad → loads road_segments_tehran, road_segments_mashhad
ROAD_GRAPH_REGIONS=
ROAD_GRAPH_LOAD_TIMEOUT_SEC=180

# ── Routing backend ────────────────────────────────────────────────────────────
# internal = in-process A* + Yen's (default)
# osrm     = OSRM primary with internal fallback
ROUTING_BACKEND=internal
OSRM_BASE_URL=http://osrm:5000
ROUTING_TIMEOUT_MS=30000
ROUTING_MAX_IN_FLIGHT=100
INTERNAL_ROUTING_MAX_IN_FLIGHT=4
OSRM_ROUTING_MAX_IN_FLIGHT=100
ROUTING_QUEUE_TIMEOUT_MS=1000
ROUTING_YEN_SPUR_CAP=60
ROUTING_MAX_ALTERNATIVES=1
ROUTE_CACHE_PRECISION=5
INTERNAL_GRAPH_ENABLED=true
INTERNAL_GRAPH_LAZY_LOAD=false
INTERNAL_GRAPH_REQUIRED=true
AVG_SPEED_KMH=40

# ── GPS processing ─────────────────────────────────────────────────────────────
GPS_RATE_LIMIT_MS=3000
DEVIATION_THRESH_KM=0.05
BATCH_SIZE=500
BATCH_FLUSH_SEC=2

# ── Laravel shipment DB (read-only, for nearby search + trip authorization) ────
# Connect to the same PostgreSQL database used by MrchamedonBeta / Laravel.
# From Docker use host.docker.internal or the shared postgres service hostname.
SHIPMENT_DB_DRIVER=postgres
SHIPMENT_DB_DSN=host=host.docker.internal port=5432 user=readonly_user password=change_me dbname=mr_chamedon sslmode=disable
SHIPMENT_TABLE=shipments
SHIPMENT_ORIGIN_LOCATION_COLUMN=start_location
SHIPMENT_END_LOCATION_COLUMN=end_location
SHIPMENT_WEIGHT_COLUMN=package_length
SHIPMENT_SEARCH_RADIUS_KM=2
SHIPMENT_SEARCH_LIMIT=100

# Vehicle types enrichment (vehicles[] in WebSocket responses)
VEHICLE_TYPES_TABLE=vehicle_types
VEHICLE_TYPE_LABEL_COLUMN=label
VEHICLE_TYPE_TITLE_COLUMN=title

# Legacy vehicle box sizes (optional)
VEHICLE_BOX_SIZES_TABLE=vehicle_box_sizes
VEHICLE_ID_COLUMN=vehicle_id
VEHICLE_WEIGHT_COLUMN=standard_length

# Content type image (optional)
CONTENT_TYPES_TABLE=content_types
CONTENT_TYPE_ID_COLUMN=content_type_id
CONTENT_TYPE_IMAGE_COLUMN=image

# Shipment package images (optional — adds images[] array)
SHIPMENT_IMAGES_TABLE=shipment_images
SHIPMENT_IMAGE_SHIPMENT_ID_COLUMN=shipment_id
SHIPMENT_IMAGE_COLUMN=image

# ── Driver live location (Redis GEO) ───────────────────────────────────────────
DRIVER_GEO_KEY=drivers:geo
DRIVER_LOCATION_STREAM_KEY=driver:locations:stream
DRIVER_SEARCH_RADIUS_KM=20

# ── Security ─────────────────────────────────────────────────────────────────
# CORS + WebSocket Origin allowlist (comma-separated). Never use * in production.
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:5173

# JWT must match Laravel tymon/jwt-auth secret (JWT_SECRET in Laravel .env)
JWT_AUTH_ENABLED=true
JWT_SECRET=change_me_to_laravel_jwt_secret
JWT_ALGO=HS256

# Trip WebSocket (/ws/trip/:id) — set true in production to require JWT/API key + trip ACL
WEBSOCKET_AUTH_ENABLED=false

# Shipment nearby WebSocket (/ws/shipments/nearby) security
WS_SHIPMENT_REQUIRE_TLS=false
WS_SHIPMENT_AUTH_REQUIRED=true
WS_SHIPMENT_LEGACY_FORMAT=true
WS_SHIPMENT_MAX_PAYLOAD_BYTES=4096
WS_SHIPMENT_MAX_CONNECTIONS=2000
WS_SHIPMENT_MAX_PER_IP=10
WS_SHIPMENT_MESSAGES_PER_SEC=2
WS_SHIPMENT_MESSAGE_BURST=5
WS_SHIPMENT_IDLE_TIMEOUT_SEC=90
WS_SHIPMENT_PING_INTERVAL_SEC=30

# Optional shared API key for service-to-service calls (bypasses per-user checks)
API_KEY_ENABLED=false
API_KEY=

RATE_LIMIT_PER_MINUTE=300
REQUEST_BODY_LIMIT_BYTES=1048576

# ── Local development (no JWT on HTTP / WebSocket) ───────────────────────────
# Uncomment for testing from Postman, mobile emulator, or LAN IP without Laravel token:
#
# JWT_AUTH_ENABLED=false
# WEBSOCKET_AUTH_ENABLED=false
# WS_SHIPMENT_AUTH_REQUIRED=false
# WS_SHIPMENT_LEGACY_FORMAT=true
# WS_SHIPMENT_REQUIRE_TLS=false
# CORS_ALLOWED_ORIGINS=*
#
# Keep sim-drivers running when testing sender mode (driver.nearby):
#   docker compose --profile sim up -d sim-drivers
